  hi("CmpItemAbbr",               { fg = p.fg })
  hi("CmpItemAbbrMatch",          { fg = p.info, bold = true })
  hi("CmpItemAbbrMatchFuzzy",     { fg = p.info, bold = true })
  hi("CmpItemAbbrDeprecated",     { fg = p.fg_disabled, strikethrough = true })
  hi("CmpItemKind",               { fg = p.fg_sec })
  hi("CmpItemMenu",               { fg = p.fg_tert })

  ---------------------------------------------------------------------------
  -- Indent-blankline
  ---------------------------------------------------------------------------
  hi("IblIndent",                  { fg = p.bg_sec })
  hi("IblScope",                   { fg = p.neutral })

  ---------------------------------------------------------------------------
  -- nvim-tree / neo-tree
  ---------------------------------------------------------------------------
  hi("NvimTreeNormal",             { fg = p.fg, bg = p.bg })
  hi("NvimTreeFolderIcon",         { fg = p.fg_sec })
  hi("NvimTreeFolderName",         { fg = p.fg })
  hi("NvimTreeOpenedFolderName",   { fg = p.fg, bold = true })
  hi("NvimTreeRootFolder",         { fg = p.fg_sec, bold = true })
  hi("NvimTreeGitDirty",           { fg = p.warning })
  hi("NvimTreeGitNew",             { fg = p.info })
  hi("NvimTreeGitDeleted",         { fg = p.neutral })
  hi("NeoTreeNormal",              { fg = p.fg, bg = p.bg })
  hi("NeoTreeNormalNC",            { fg = p.fg, bg = p.bg })

  ---------------------------------------------------------------------------
  -- Terminal colors
  ---------------------------------------------------------------------------
  vim.g.terminal_color_0  = p.ansi_black
  vim.g.terminal_color_1  = p.ansi_red
  vim.g.terminal_color_2  = p.ansi_green
  vim.g.terminal_color_3  = p.ansi_yellow
  vim.g.terminal_color_4  = p.ansi_blue
  vim.g.terminal_color_5  = p.ansi_magenta
  vim.g.terminal_color_6  = p.ansi_cyan
  vim.g.terminal_color_7  = p.ansi_white
  vim.g.terminal_color_8  = p.ansi_bright_black
  vim.g.terminal_color_9  = p.ansi_bright_red
  vim.g.terminal_color_10 = p.ansi_bright_green
  vim.g.terminal_color_11 = p.ansi_bright_yellow
  vim.g.terminal_color_12 = p.ansi_bright_blue
  vim.g.terminal_color_13 = p.ansi_bright_magenta
  vim.g.terminal_color_14 = p.ansi_bright_cyan
  vim.g.terminal_color_15 = p.ansi_bright_white
end

M.setup()

return M
