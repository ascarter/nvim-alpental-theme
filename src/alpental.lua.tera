  hi("SpellRare",    { undercurl = true, sp = p.magenta })

  hi("Directory",    { fg = p.fg, bold = true })
  hi("Title",        { fg = p.fg, bold = true })
  hi("Question",     { fg = p.info })
  hi("MoreMsg",      { fg = p.info })
  hi("ModeMsg",      { fg = p.fg, bold = true })
