  hi("Pmenu",        { fg = p.fg, bg = p.bg })
  hi("PmenuSel",     { fg = p.fg, bg = p.bg_sec })
  hi("PmenuSbar",    { bg = p.bg_sec })
  hi("PmenuThumb",   { bg = p.neutral })

  hi("StatusLine",   { fg = p.fg, bg = p.status_bg })
